# cp .env.example .env

# Required for Claude AI report generation
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional — Reddit scraping (free at reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=RedtailScraper/1.0
