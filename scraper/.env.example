# ─── Rename this file to .env and fill in your keys ───────────────────────────
# None of these cost money. All free tiers.

# Reddit API — get at: reddit.com/prefs/apps → "create app" → script
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USER_AGENT=RedtailScraper/1.0

# YouTube Data API v3 (optional) — get at: console.developers.google.com
# Enable "YouTube Data API v3" → Create API Key → Free: 10,000 units/day
YOUTUBE_API_KEY=your_youtube_api_key_here

# Search target — what genre/game type to research
SEARCH_QUERY=mobile fighting game
